HOST=0.0.0.0
PORT=8000
BACKEND_BASE_URL=https://api.example.com
FRONTEND_URL=https://shop.example.com
ORIGIN=https://shop.example.com
ALLOW_MOCK_PAYMENTS=true

MOMO_PARTNER_CODE=replace-with-your-momo-partner-code
MOMO_ACCESS_KEY=replace-with-your-momo-access-key
MOMO_SECRET_KEY=replace-with-your-momo-secret-key
MOMO_PARTNER_NAME=Your Store Name
MOMO_STORE_ID=YourStoreId
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REQUEST_TYPE=payWithMethod

VNPAY_TMN_CODE=replace-with-your-vnpay-tmn-code
VNPAY_HASH_SECRET=replace-with-your-vnpay-hash-secret
